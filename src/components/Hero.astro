---
// Signal Entry — Scene 1
// Title characters are split at build-time so no runtime layout shift occurs.
const eyebrow = "SIGNAL // BTB";
const title = "BEYOND THE BASICS";
const subtitle = `A transmission from a mind that doesn't sit still — <em>football tactics, code, books, music, growth</em> — tuned weekly.`;

// Split title into per-char spans for the reveal
function splitChars(str: string) {
  return str.split(' ').map((word) => ({
    word,
    chars: Array.from(word),
  }));
}

const titleWords = splitChars(title);
---

<section class="signal-entry" id="signal-entry" data-scene="1">
  <div class="signal-entry-inner">
    <div class="signal-text-layer">

      <div class="signal-label signal-magnetic">
        <span>{eyebrow}</span>
        <span class="signal-label-channel">CH.047</span>
      </div>

      <h1 class="signal-title" aria-label={title}>
        {titleWords.map((word, wi) => {
          let charIndex = 0;
          // Build the absolute char index offset including prior words
          const offset = titleWords.slice(0, wi).reduce((n, w) => n + w.chars.length, 0);
          return (
            <span class="signal-word">
              {word.chars.map((ch, ci) => (
                <span
                  class="signal-char"
                  data-char={ch}
                  data-char-index={offset + ci}
                  style={`--char-index: ${offset + ci}`}
                  aria-hidden="true"
                >{ch}</span>
              ))}
            </span>
          );
        })}
      </h1>

      <p class="signal-subtitle" set:html={subtitle}></p>

      <div class="signal-cta-group">
        <a href="/blog" class="btn-primary signal-magnetic">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M4 4l7.07 17 2.51-7.39L21 11.07z"/>
          </svg>
          Tune In to the Blog
        </a>
        <a href="/about" class="btn-ghost signal-magnetic">
          Decode the Signal
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

    </div>

    <!-- Hidden trigger zone T01 — bottom-right corner, 60x60px -->
    <div class="trigger-zone" data-trigger-id="T01" aria-hidden="true"
         style="bottom: 0; right: 0; width: 60px; height: 60px; position: absolute;"></div>
  </div>

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    <span>scroll to tune</span>
    <div class="scroll-hint-line"></div>
  </div>
</section>

<style>
  .signal-entry {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    overflow: hidden;
  }

  .signal-entry-inner {
    position: relative;
    width: 100%;
    max-width: 1040px;
    padding: 0 clamp(1rem, 4vw, 2rem);
    text-align: center;
    z-index: 10;
  }

  /* Additional label extras */
  .signal-label {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
    padding: 0.55rem 1rem;
    border-radius: 100px;
    border: 1px solid color-mix(in srgb, var(--accent-1) 30%, transparent);
    background: color-mix(in srgb, var(--bg-color) 60%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .signal-label-channel {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--muted-text);
    padding-left: 1rem;
    border-left: 1px solid color-mix(in srgb, var(--accent-1) 40%, transparent);
  }

  .signal-label::before { opacity: 0; display: none; }
  .signal-label::after { position: relative; left: 0; }

  /* Polished CTA buttons */
  .signal-cta-group .btn-primary,
  .signal-cta-group .btn-ghost {
    padding: 0.95rem 1.6rem;
    border-radius: 100px;
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    transition:
      transform 280ms var(--ease-spring),
      box-shadow 280ms ease,
      background 280ms ease,
      border-color 280ms ease,
      filter 280ms ease;
    position: relative;
    overflow: hidden;
  }

  .signal-cta-group .btn-primary {
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    color: var(--btn-primary-text);
    box-shadow: var(--btn-primary-shadow);
    border: 1px solid transparent;
  }

  .signal-cta-group .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent-1) 90%, white), color-mix(in srgb, var(--accent-2) 90%, white));
    opacity: 0;
    transition: opacity 280ms ease;
  }

  .signal-cta-group .btn-primary:hover::before { opacity: 1; }
  .signal-cta-group .btn-primary > * { position: relative; z-index: 1; }

  .signal-cta-group .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--btn-primary-shadow-hover);
  }

  .signal-cta-group .btn-ghost {
    background: var(--btn-ghost-bg);
    border: 1px solid var(--btn-ghost-border);
    color: var(--text-color);
  }

  .signal-cta-group .btn-ghost:hover {
    background: var(--btn-ghost-hover-bg);
    border-color: var(--btn-ghost-hover-border);
    box-shadow: var(--btn-ghost-hover-shadow);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .signal-entry-inner { padding: 0 1rem; }
    .signal-label-channel { font-size: 0.55rem; }
    .signal-cta-group { flex-direction: column; width: 100%; }
    .signal-cta-group .btn-primary,
    .signal-cta-group .btn-ghost { justify-content: center; width: 100%; }
  }
</style>

<script is:inline>
  /*
    Signal Entry — character-level reveal orchestrator.
    Listens to signal:stable + subscribes to --signal-phase via
    requestAnimationFrame polling to drive per-char progress.
  */
  (() => {
    const chars = Array.from(document.querySelectorAll('#signal-entry .signal-char'));
    if (!chars.length) return;

    const total = chars.length;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced) {
      chars.forEach(c => {
        c.style.setProperty('--char-progress', '1');
        c.style.setProperty('--char-opacity', '1');
      });
      return;
    }

    // Initial state — all chars invisible
    chars.forEach((c, i) => {
      c.style.setProperty('--char-progress', '0');
      c.style.setProperty('--char-opacity', '0');
    });

    // Drive char reveal from signalPhase. Each character has its own
    // per-character phase that starts progressing once the overall
    // signalPhase crosses a threshold based on its index.
    function frame() {
      const phase = parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue('--signal-phase')
      ) || 0;
      // Map overall phase to per-char progress with stagger
      // First char reveals when phase=0.08, last at phase=0.95
      for (let i = 0; i < total; i++) {
        const charStart = 0.08 + (i / total) * 0.72;
        const charEnd = charStart + 0.22;
        const raw = (phase - charStart) / (charEnd - charStart);
        const clamped = Math.max(0, Math.min(1, raw));
        // Cubic ease-out
        const eased = 1 - Math.pow(1 - clamped, 3);
        chars[i].style.setProperty('--char-progress', eased.toFixed(3));
        chars[i].style.setProperty('--char-opacity', eased.toFixed(3));
      }
      if (phase < 1) requestAnimationFrame(frame);
      else {
        // Final state — remove custom prop to let default take over
        chars.forEach(c => {
          c.style.setProperty('--char-progress', '1');
          c.style.setProperty('--char-opacity', '1');
        });
      }
    }
    requestAnimationFrame(frame);

    // --- Trigger T02 — triple-click the title in under 2s ---
    const title = document.querySelector('.signal-title');
    if (title && window.BTB?.signal?.state) {
      let clicks = [];
      title.addEventListener('click', () => {
        const now = performance.now();
        clicks.push(now);
        clicks = clicks.filter(t => now - t < 2000);
        if (clicks.length >= 3) {
          clicks = [];
          if (window.BTB.signal.state.activateTrigger('T02')) {
            const chars = title.querySelectorAll('.signal-char');
            const original = [];
            chars.forEach((c) => {
              original.push(c.textContent);
              c.textContent = String.fromCharCode(33 + Math.floor(Math.random() * 90));
            });
            setTimeout(() => {
              chars.forEach((c, i) => c.textContent = original[i]);
            }, 600);
          }
        }
      });
    }

    // --- Trigger T01 — hover bottom-right corner 1.5s ---
    const t01 = document.querySelector('.trigger-zone[data-trigger-id="T01"]');
    if (t01 && window.BTB?.signal?.state) {
      let hoverTimer = null;
      t01.addEventListener('mouseenter', () => {
        hoverTimer = setTimeout(() => {
          if (window.BTB.signal.state.activateTrigger('T01')) {
            showCornerMessage();
          }
        }, 1500);
      });
      t01.addEventListener('mouseleave', () => {
        if (hoverTimer) { clearTimeout(hoverTimer); hoverTimer = null; }
      });
    }

    function showCornerMessage() {
      // --- Particle letterform: "still here?" assembles from chaos ---
      const PARTICLE_COUNT = 200;
      const TEXT = 'still here?';
      const W = window.innerWidth;
      const H = window.innerHeight;

      // Create offscreen canvas to get glyph positions
      const offscreen = document.createElement('canvas');
      offscreen.width = 320;
      offscreen.height = 40;
      const octx = offscreen.getContext('2d');
      octx.fillStyle = '#fff';
      octx.font = '600 22px "JetBrains Mono", monospace';
      octx.textBaseline = 'middle';
      octx.fillText(TEXT, 10, 20);

      // Sample white pixels to get target positions
      const imageData = octx.getImageData(0, 0, 320, 40);
      const targets = [];
      for (let y = 0; y < 40; y += 2) {
        for (let x = 0; x < 320; x += 2) {
          const idx = (y * 320 + x) * 4;
          if (imageData.data[idx] > 128) {
            targets.push({ x, y });
          }
        }
      }

      // Distribute particles to target positions
      const stride = Math.max(1, Math.floor(targets.length / PARTICLE_COUNT));
      const selected = [];
      for (let i = 0; i < targets.length && selected.length < PARTICLE_COUNT; i += stride) {
        selected.push(targets[i]);
      }

      // Origin point: bottom-right of screen
      const originX = W - 100;
      const originY = H - 60;
      const offsetX = W - 360;
      const offsetY = H - 80;

      // Create particle canvas
      const pCanvas = document.createElement('canvas');
      pCanvas.width = W;
      pCanvas.height = H;
      pCanvas.style.cssText = `
        position: fixed; inset: 0;
        width: 100vw; height: 100vh;
        z-index: 9999; pointer-events: none;
        opacity: 0; transition: opacity 400ms ease;
      `;
      document.body.appendChild(pCanvas);
      requestAnimationFrame(() => { pCanvas.style.opacity = '1'; });

      const pctx = pCanvas.getContext('2d');

      // Particles: start scattered, converge to glyph positions
      const cs = getComputedStyle(document.documentElement);
      const accent = cs.getPropertyValue('--accent-1').trim() || '#4cc9f0';

      const particles = selected.map(t => ({
        x: originX + (Math.random() - 0.5) * 300,
        y: originY + (Math.random() - 0.5) * 200,
        tx: offsetX + t.x,
        ty: offsetY + t.y,
        vx: 0, vy: 0,
        size: 1.2 + Math.random() * 1.5,
      }));

      const startT = performance.now();
      const DURATION = 2400;
      const ASSEMBLE = 1200;  // time to reach targets
      const HOLD = 800;       // time to hold
      const DISSOLVE = 400;   // fade out

      function animate(now) {
        const elapsed = now - startT;
        if (elapsed > DURATION) {
          pCanvas.style.opacity = '0';
          setTimeout(() => pCanvas.remove(), 500);
          return;
        }

        pctx.clearRect(0, 0, W, H);

        const phase = Math.min(1, elapsed / ASSEMBLE);
        // Quartic ease-out
        const ease = 1 - Math.pow(1 - phase, 4);
        const dissolvePhase = elapsed > (ASSEMBLE + HOLD)
          ? (elapsed - ASSEMBLE - HOLD) / DISSOLVE
          : 0;

        for (const p of particles) {
          // Spring toward target
          const dx = p.tx - p.x;
          const dy = p.ty - p.y;
          p.vx += dx * 0.08 * ease;
          p.vy += dy * 0.08 * ease;
          p.vx *= 0.82;
          p.vy *= 0.82;

          // Add noise when not yet assembled
          if (phase < 0.8) {
            p.vx += (Math.random() - 0.5) * (1 - ease) * 4;
            p.vy += (Math.random() - 0.5) * (1 - ease) * 4;
          }

          p.x += p.vx;
          p.y += p.vy;

          const alpha = Math.max(0, (0.5 + ease * 0.5) * (1 - dissolvePhase));
          const glow = phase > 0.6 ? (phase - 0.6) * 2.5 : 0;

          pctx.beginPath();
          pctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          pctx.fillStyle = accent;
          pctx.globalAlpha = alpha;
          pctx.fill();

          if (glow > 0) {
            pctx.beginPath();
            pctx.arc(p.x, p.y, p.size + 3, 0, Math.PI * 2);
            pctx.fillStyle = accent;
            pctx.globalAlpha = alpha * glow * 0.3;
            pctx.fill();
          }
        }

        pctx.globalAlpha = 1;
        requestAnimationFrame(animate);
      }

      requestAnimationFrame(animate);
    }
  })();
</script>
