---
interface Props {
  categories: string[];
}

const { categories = [] } = Astro.props;
---
<div class="blog-controls reveal" aria-label="Blog controls">
  <div class="command-bar-shell">
    <label class="visually-hidden" for="search-input">Search blog posts</label>
    <div class="command-bar">
      <div class="command-bar-leading" aria-hidden="true">
        <svg class="search-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
          <circle cx="11" cy="11" r="7.5"></circle>
          <line x1="20" y1="20" x2="16.65" y2="16.65"></line>
        </svg>
      </div>

      <input
        type="text"
        id="search-input"
        placeholder="Search titles, excerpts, and categories"
        class="search-bar"
        autocomplete="off"
        spellcheck="false"
      />

      <div class="command-bar-shortcuts" aria-hidden="true">
        <kbd>Ctrl</kbd>
        <span>/</span>
        <kbd>K</kbd>
      </div>
    </div>

    <div class="command-bar-meta">
      <p class="search-status" id="search-status">Search titles, excerpts, and categories.</p>
      <button class="command-clear" id="search-clear" type="button" hidden>Clear</button>
    </div>
  </div>

  <div class="filter-rail" id="blog-filter-rail" aria-label="Filter posts by category">
    <div class="filter-indicator" id="filter-indicator" aria-hidden="true"></div>

    <button class="filter-btn active" data-filter="all" type="button" aria-pressed="true">
      <span>All</span>
      <span class="filter-count" data-count-for="all">0</span>
    </button>

    <button class="filter-btn" data-filter="bookmarks" id="filter-bookmarks" type="button" aria-pressed="false">
      <span>Bookmarks</span>
      <span class="filter-count" data-count-for="bookmarks">0</span>
    </button>

    {
      categories.map((category) => (
        <button class="filter-btn" data-filter={category} type="button" aria-pressed="false">
          <span>{category}</span>
          <span class="filter-count" data-count-for={category}>0</span>
        </button>
      ))
    }
  </div>
</div>
