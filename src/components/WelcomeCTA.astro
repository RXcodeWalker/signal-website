---
---
<section class="section" data-handshake style="margin-top: 1rem;">
  <div class="feature-card feature-card-large">
    <div class="feature-card-accent" style="width: 300px; height: 300px; top: -100px; right: -100px; opacity: 0.15;"></div>
    <div style="position: relative; z-index: 2; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 2rem;">
      <div>
        <div class="feature-card-tag">Get in touch</div>
        <h3 style="font-size: 2rem; margin-bottom: 0.5rem;">Let's talk football<br>or build something cool</h3>
        <p style="max-width: 500px;">Whether you want to debate Arsenal's best XI, collab on a project, or just say hi — my inbox is open.</p>
      </div>
      <a href="/contact" class="btn-primary" style="flex-shrink: 0;">
        Say Hello
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.07 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 013 .95h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .feature-card {
    position: relative;
    padding: 1.85rem;
    border-radius: var(--card-radius);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    overflow: hidden;
    transform: translate3d(0, 0, 0);
    transition:
      transform var(--haptic-duration-out) var(--curve-haptic-recover),
      box-shadow 320ms ease,
      border-color 260ms ease,
      filter 260ms ease,
      background 260ms ease;
    text-decoration: none;
    color: var(--text-color);
    display: block;
  }
  .feature-card:hover {
    transform: translate3d(0, var(--haptic-lift), 0) scale(var(--haptic-hover-scale));
    transition-timing-function: var(--curve-haptic-overshoot);
    box-shadow: var(--glass-shadow-hover);
    border-color: var(--accent-1);
    filter: saturate(var(--surface-contrast-hover));
  }
  .feature-card:active {
    transform: translate3d(0, calc(var(--haptic-lift) * 0.35), 0) scale(var(--haptic-press-scale));
    transition-duration: var(--haptic-duration-in);
    transition-timing-function: var(--curve-haptic-compress);
    filter: saturate(var(--surface-contrast-press));
  }
  .feature-card-accent {
    position: absolute;
    top: 0; right: 0;
    width: 120px; height: 120px;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.2;
    background: var(--accent-1);
    transition: all 0.4s ease;
  }
  .feature-card:hover .feature-card-accent {
    opacity: 0.4;
    transform: scale(1.3);
  }
  .feature-card-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-1);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .feature-card-tag::before {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--accent-1);
  }
  .feature-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-color);
  }
  .feature-card p {
    color: var(--muted-text);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .feature-card-large {
    grid-column: 1 / -1;
    padding: 2.6rem;
    background: linear-gradient(135deg, 
      rgba(76,201,240,0.08) 0%,
      rgba(138,79,255,0.05) 100%
    );
  }
  .feature-card-large h3 { font-size: 1.8rem; }

  @media (max-width: 768px) {
    .feature-card { padding: 1.25rem !important; }
    .feature-card-large { padding: 1.5rem !important; }
  }
</style>
