<header class="site-header" id="header">
    <style>
      /* Quick fix to make links and buttons align perfectly on one row */
      .main-nav { display: flex; align-items: center; justify-content: space-between; }
      .nav-links { margin: 0; padding: 0; display: flex; align-items: center; }
    </style>
    
    <div class="container">
      <nav class="main-nav">

        <a href="/" class="brand" style="text-decoration:none;">Beyond The Basics</a>

        <ul class="nav-links" id="mobile-menu">
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/#newsletter-signup">Subscribe</a></li>
        </ul>

        <div class="nav-right">
          
          <button id="cursor-toggle" class="theme-btn cursor-btn" aria-label="Toggle cursor" title="Toggle custom cursor">
            <svg class="cursor-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4l7.07 17 2.51-7.39L21 11.07z"/>
            </svg>
          </button>

          <button id="ambient-toggle" class="theme-btn ambient-btn" aria-label="Toggle ambient sound" title="Toggle ambient sound">
            <svg class="headphone-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 18v-6a9 9 0 0 1 18 0v6"></path>
              <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path>
            </svg>
            <div class="eq-bars">
              <div class="eq-bar"></div>
              <div class="eq-bar"></div>
              <div class="eq-bar"></div>
            </div>
          </button>

          <button id="theme-toggle" class="theme-btn" aria-label="Toggle dark mode">
            <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>

          <button
            class="menu-toggle"
            id="menu-toggle"
            aria-label="Toggle menu"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <span></span><span></span><span></span>
          </button>
        </div>

      </nav>
    </div>
</header>
<div id="nav-backdrop" aria-hidden="true"></div>
