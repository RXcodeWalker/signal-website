---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Stats from '../components/Stats.astro';
import Skills from '../components/Skills.astro';
import AboutStrip from '../components/AboutStrip.astro';
import WelcomeCTA from '../components/WelcomeCTA.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPost = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())[0];
---

<BaseLayout title="Om — Home">
  
  <Hero />
  <Marquee />

  <main class="container main-content home-main">
    
    <!-- LATEST BLOG DROPS -->
    <section class="section" data-handshake style="margin:1rem; padding:1rem; align-content: center;">
      <div class="section-label">Fresh Off The Press</div>
      <h2 class="section-heading hs-heading"><span>Latest drops</span></h2>

      <div class="featured-grid" >
        <div class="feature-card tilt-card" id="latest-post-card">
          <div class="card-shine"></div>
          <div class="feature-card-accent"></div>
          <div class="feature-card-tag">Latest Post</div>
          <div id="latest-post-inner">
            {latestPost ? (
              <>
                <h3 style="font-family:var(--font-display);font-weight:700;font-size:1.3rem;margin-bottom:0.75rem;">{latestPost.data.title}</h3>
                <div class="blog-meta">
                  <span class="category-badge">{latestPost.data.category}</span>
                  <span class="blog-date">{latestPost.data.date}</span>
                </div>
                <p class="text-muted" style="font-size:0.9rem;line-height:1.6;margin-bottom:1.5rem;">{latestPost.data.excerpt}</p>
                <a href={`/blog/${latestPost.slug}`} class="feature-card-arrow">
                  Read post
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              </>
            ) : (
              <h3>No posts found.</h3>
            )}
          </div>
        </div>
      </div>
    </section>

    <section id="newsletter-signup" class="section newsletter-home-section" data-handshake aria-label="Newsletter signup">
      <div class="feature-card newsletter-home-card">
        <div class="feature-card-accent newsletter-home-accent"></div>
        <div class="newsletter-home-copy">
          <div class="feature-card-tag">Newsletter</div>
          <h3>Get new posts in your inbox</h3>
          <p class="text-muted">
            Weekly notes on coding, robotics, books, music, and sports analysis. No spam, just sharp ideas and real progress.
          </p>
        </div>
        <div class="newsletter-home-actions">
          <a href="/blog" class="btn-primary">Read recent posts</a>
          <a href="/contact" class="btn-ghost">Subscribe via email</a>
        </div>
      </div>
    </section>

    <Stats />
    <Skills />
    <AboutStrip />
    <WelcomeCTA />

  </main>

  <style>
    /* Page specific layout */
    .home-main {
      padding-top: 0;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }
    :global(.home-main > *) {
      margin-top: 0 !important;
      margin-bottom: 0 !important;
    }
    .featured-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    @media (max-width: 640px) {
      .featured-grid { grid-template-columns: 1fr; }
    }

    .feature-card {
      position: relative;
      padding: 1.85rem;
      border-radius: var(--card-radius);
      background: var(--glass-bg);
      backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
      border: 1px solid var(--glass-border);
      box-shadow: var(--glass-shadow);
      overflow: hidden;
      transform: translate3d(0, 0, 0);
      transition:
        transform var(--haptic-duration-out) var(--curve-haptic-recover),
        box-shadow 320ms ease,
        border-color 260ms ease,
        filter 260ms ease,
        background 260ms ease;
      text-decoration: none;
      color: var(--text-color);
      display: block;
    }
    .feature-card:hover {
      transform: translate3d(0, var(--haptic-lift), 0) scale(var(--haptic-hover-scale));
      transition-timing-function: var(--curve-haptic-overshoot);
      box-shadow: var(--glass-shadow-hover);
      border-color: var(--accent-1);
      filter: saturate(var(--surface-contrast-hover));
    }
    .feature-card:active {
      transform: translate3d(0, calc(var(--haptic-lift) * 0.35), 0) scale(var(--haptic-press-scale));
      transition-duration: var(--haptic-duration-in);
      transition-timing-function: var(--curve-haptic-compress);
      filter: saturate(var(--surface-contrast-press));
    }
    .feature-card-accent {
      position: absolute;
      top: 0; right: 0;
      width: 120px; height: 120px;
      border-radius: 50%;
      filter: blur(50px);
      opacity: 0.2;
      background: var(--accent-1);
      transition: all 0.4s ease;
    }
    .feature-card:hover .feature-card-accent {
      opacity: 0.4;
      transform: scale(1.3);
    }
    .feature-card-tag {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent-1);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .feature-card-tag::before {
      content: '';
      width: 20px;
      height: 1px;
      background: var(--accent-1);
    }
    .feature-card h3 {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      color: var(--text-color);
    }
    .feature-card-arrow {
      margin-top: 1.5rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-display);
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--accent-1);
      transition: gap 240ms var(--curve-haptic-recover), filter 240ms ease;
    }
    .feature-card:hover .feature-card-arrow {
      gap: 0.72rem;
      filter: saturate(var(--surface-contrast-hover));
    }
    .newsletter-home-section {
      margin: 0.15rem 0 0.35rem;
      padding: 0;
    }
    .newsletter-home-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      padding: 2rem;
    }
    .newsletter-home-accent {
      width: 180px;
      height: 180px;
      opacity: 0.16;
    }
    .newsletter-home-copy h3 {
      margin-bottom: 0.6rem;
      font-size: 1.45rem;
    }
    .newsletter-home-copy p {
      margin: 0;
      max-width: 760px;
      line-height: 1.65;
      font-size: 0.95rem;
    }
    .newsletter-home-actions {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      flex-wrap: wrap;
      flex-shrink: 0;
    }
    :global(.home-main .stats-section) {
      padding: 1rem 0 !important;
    }
    :global(.home-main .about-strip) {
      padding: 1.1rem 0 !important;
    }
    :global(.home-main .section) {
      margin-top: 0.2rem !important;
      margin-bottom: 0.35rem !important;
    }

    @media (max-width: 768px) {
      .home-main {
        padding-top: 0.5rem !important;
        padding-bottom: 1.25rem !important;
        gap: 0.4rem !important;
      }
      .section { margin-bottom: 0.45rem !important; margin-top: 0.35rem !important; }
      .section-heading { margin-bottom: 1.25rem !important; font-size: 2.2rem !important; }
      .featured-grid { gap: 1rem !important; }
      .newsletter-home-section { margin: 0.1rem 0 0.3rem !important; padding: 0 !important; }
      :global(.home-main .stats-section) { padding: 0.7rem 0 !important; }
      :global(.home-main .about-strip) { padding: 0.8rem 0 !important; }
      .newsletter-home-card {
        flex-direction: column;
        align-items: flex-start;
        padding: 1.5rem;
      }
    }
  </style>

  <script is:inline>
    // 3D TILT CARDS
    (() => {
      'use strict';

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const hoverCapable = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      if (reducedMotion || !hoverCapable) return;

      document.querySelectorAll('.tilt-card').forEach(card => {
        if (card.dataset.tiltBound === 'true') return;
        card.dataset.tiltBound = 'true';

        card.addEventListener('mousemove', e => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left, y = e.clientY - rect.top;
          const centerX = rect.width / 2, centerY = rect.height / 2;
          const rotateX = (y - centerY) / centerY * -8, rotateY = (x - centerX) / centerX * 8;
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateZ(10px)`;
          card.style.setProperty('--mouse-x', (x / rect.width * 100) + '%');
          card.style.setProperty('--mouse-y', (y / rect.height * 100) + '%');
        });
        card.addEventListener('mouseleave', () => card.style.transform = '');
      });
    })();
  </script>
</BaseLayout>
