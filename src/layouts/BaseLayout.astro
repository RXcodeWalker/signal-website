---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  title = "Signal // BTB",
  description = "A transmission from a mind that doesn't sit still.",
  hideNav = false,
  hideFooter = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-gl="pending" data-probe="pending">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="dark light">
  <meta name="theme-color" content="#060c1c">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <title>{title}</title>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />

  <!-- Typography -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Synchronous state bootstrap: runs before first paint so
       temporal identity + behavioral memory are applied in time. -->
  <script is:inline src="/js/engine/state.js"></script>

  <ClientRouter />
  <slot name="head" />
</head>
<body class="loaded" data-theme-ready>

  <!-- WebGL distortion canvas (fixed, behind everything) -->
  <canvas id="signal-canvas" aria-hidden="true"></canvas>

  <!-- Full-screen noise overlay (drives grain texture) -->
  <div class="signal-noise" aria-hidden="true"></div>

  <!-- Scanline CRT overlay (low opacity, atmosphere only) -->
  <div class="signal-scanlines" aria-hidden="true"></div>

  <!-- Scan line sweep (animated during scene entry) -->
  <div class="signal-scan-line" aria-hidden="true"></div>

  <!-- Probe cursor (created by probe.js if supported) -->

  <!-- Signal state anchor (hidden) -->
  <div id="signal-state" aria-hidden="true"></div>

  {!hideNav && <Navbar />}

  <slot />

  {!hideFooter && <Footer />}

  <!-- Reticle (positioned by signal.js, never created at runtime) -->
  <div id="reticle" aria-hidden="true">
    <span class="ret-corner ret-tl"></span>
    <span class="ret-corner ret-tr"></span>
    <span class="ret-corner ret-bl"></span>
    <span class="ret-corner ret-br"></span>
  </div>

  <!-- Awareness lines (hidden debug-style overlay text) -->
  <div class="awareness-line" data-awareness-line="1" aria-hidden="true">// signal.tuned = true</div>
  <div class="awareness-line" data-awareness-line="2" aria-hidden="true">// presence.detected</div>
  <div class="awareness-line" data-awareness-line="3" aria-hidden="true">// transmission.depth &gt; 0.70</div>
  <div class="awareness-line" data-awareness-line="4" aria-hidden="true">// observer.observed</div>

  <!-- ============================================================
       SIGNAL ENGINE — loaded in strict dependency order
       state.js is already in <head>. These come after content.
       ============================================================ -->
  <script is:inline src="/js/engine/signal-gl.js"></script>
  <script is:inline src="/js/engine/probe.js"></script>
  <script is:inline src="/js/engine/physics.js"></script>
  <script is:inline src="/js/engine/awareness.js"></script>
  <script is:inline src="/js/engine/audio-engine.js"></script>

  <!-- Legacy scripts (theme toggle, nav, ambient audio, konami, interactions) -->
  <script is:inline src="/js/theme.js"></script>
  <script is:inline src="/js/scroll.js"></script>
  <script is:inline src="/js/sound.js"></script>
  <script is:inline src="/js/konami.js"></script>
  <script is:inline src="/js/signal.js"></script>

</body>
</html>
